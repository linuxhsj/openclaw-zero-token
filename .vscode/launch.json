{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Onboard (Hot Reload)",
            "program": "${workspaceFolder}/src/entry.ts",
            "args": [
                "onboard",
            ],
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "tsx",
            "runtimeArgs": [
                "--enable-source-maps",
            ],
            "sourceMaps": true,
            "trace": true,
            "timeout": 30000,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "OPENCLAW_CONFIG_PATH": "${workspaceFolder}/.openclaw-upstream-state/openclaw.json",
                "OPENCLAW_STATE_DIR": "${workspaceFolder}/.openclaw-upstream-state",
                "OPENCLAW_GATEWAY_PORT": "3002",
            }
        },
        {
            "name": "Debug WebAuth (Hot Reload)",
            "program": "${workspaceFolder}/src/entry.ts",
            "args": [
                "webauth",
            ],
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "tsx",
            "runtimeArgs": [
                "--enable-source-maps",
            ],
            "sourceMaps": true,
            "trace": true,
            "timeout": 30000,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "OPENCLAW_CONFIG_PATH": "${workspaceFolder}/.openclaw-upstream-state/openclaw.json",
                "OPENCLAW_STATE_DIR": "${workspaceFolder}/.openclaw-upstream-state",
                "OPENCLAW_GATEWAY_PORT": "3002",
            }
        },
        {
            "name": "Debug Gateway (server.sh - Hot Reload)",
            "program": "${workspaceFolder}/src/entry.ts",
            "args": [
                "gateway",
                "--port",
                "3002"
            ],
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "tsx",
            "runtimeArgs": [
                "--enable-source-maps",
            ],
            "sourceMaps": true,
            "trace": true,
            "timeout": 30000,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "OPENCLAW_CONFIG_PATH": "${workspaceFolder}/.openclaw-upstream-state/openclaw.json",
                "OPENCLAW_STATE_DIR": "${workspaceFolder}/.openclaw-upstream-state",
                "OPENCLAW_GATEWAY_PORT": "3002",
            }
        },
        {
            "name": "Debug UI Build",
            "program": "${workspaceFolder}/scripts/ui.js",
            "args": [
                "build"
            ],
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "tsx",
            "runtimeArgs": [
                "--enable-source-maps",
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Attach to Process",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "cwd": "${workspaceFolder}"
        }
    ]
}
